{
  "name": "mindclaw",
  "version": "0.2.1",
  "description": "Pluggable AI middleware proxy for OpenClaw — intercepts, enriches, and routes LLM traffic",
  "type": "module",
  "bin": {
    "mindclaw": "./bin/mindclaw.mjs"
  },
  "main": "./src/index.mjs",
  "scripts": {
    "start": "node bin/mindclaw.mjs",
    "dev": "node --watch bin/mindclaw.mjs",
    "test": "node --test test/test-all.mjs",
    "migrate": "node bin/migrate-memory.mjs",
    "migrate:dry": "node bin/migrate-memory.mjs --dry-run"
  },
  "keywords": ["openclaw", "llm", "proxy", "middleware", "ai-agent"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
